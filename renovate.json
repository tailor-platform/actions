{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>tailor-inc/renovate-config",
    ":pinAllExceptPeerDependencies",
    ":disableDependencyDashboard"
  ],
  "dependencyDashboardApproval": false,
  "timezone": "Asia/Tokyo",
  "schedule": ["* 9-18 * * 1-5"],
  "packageRules": [
    {
      "description": "Enable major updates without dashboard approval (dashboard is disabled)",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": false
    },
    {
      "description": "Enable renovate for tests directory",
      "matchPaths": ["tests/**"],
      "enabled": true
    }
  ]
}
